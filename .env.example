# Copy to .env and adjust. Compose falls back to these same defaults if no .env exists.

# Database
MYSQL_ROOT_PASSWORD=hucha-root
MYSQL_DATABASE=finance
MYSQL_USER=finance
MYSQL_PASSWORD=finance-pw

# Shared secret required by POST /api/ingest (automation entry point)
INGEST_TOKEN=dev-ingest-token

# Backups: cron expression + days of dumps to keep in ./backups
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=14
